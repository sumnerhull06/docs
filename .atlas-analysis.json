  "keyFeatures": [
    "Hosted Authorize.Net checkout — card data never touches your server",
    "Automatic payment sync back to RepairDesk invoices after capture",
    "Idempotent payment recording to prevent duplicate charges",
    "Chrome extension and userscript to inject a pay button into RepairDesk POS",
    "Session status polling for real-time payment confirmation",
    "RepairDesk API key and OAuth 2.0 authentication support",
    "Sandbox and production Authorize.Net environments"
  ],
  "publicApiSurface": [
    "POST /api/payments/sessions",
